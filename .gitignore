.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# AWS CDK
cdk.out/
cdk.context.json

# Relay config (live config files — only examples are committed)
config/rotations.yaml
config/escalation.yaml
config/routing.yaml

# Secrets / credentials — never commit these
.env
.env.*
.env_info
*.env_info
*.pem
*.key
secrets.yaml
credentials.yaml

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# AWS SAM (if used alongside CDK)
.aws-sam/

# Terraform / Terragrunt (local state, provider plugins, generated files —
# never committed; the committed .tf/.hcl source is authoritative)
.terraform/
.terraform.lock.hcl
.terragrunt-cache/
*.tfstate
*.tfstate.*
*.tfplan
# Terragrunt generates these from the root config at apply time:
backend.tf
provider.tf

# Node.js (CDK CLI dependency)
node_modules/
package-lock.json
yarn.lock

# uv lock file — not committed (resolved per-environment; CI uses pyproject)
uv.lock
.env_info
.env

# CDK deploy outputs
cdk.outputs.json

.debug

# Tool caches
.ruff_cache/

# mkdocs build output (generated; published by CI, not committed)
site/

# Local agent/session state — but DO share project commands (e.g. /dod) with the team.
.claude/*
!.claude/commands/
.claude/commands/*
!.claude/commands/*.md

# Operator-local deploy wrappers (env-specific, never published)
scripts/*.local.sh

# Transient SDD planning artifacts (plan/research/tasks scratchpads) — history lives in GitHub issues
specs/_active/
# spec-kit per-feature pointer (transient; set by setup-plan per active feature)
.specify/feature.json

# docs-shots capture harness
tools/docs-shots/node_modules/
tools/docs-shots/videos/
tools/docs-shots/package-lock.json
